      </connection>
      <aliases enabled='yes' />
      <column datatype='real' name='[Calculation1]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales]))'>
          <table-calc ordering-type='Columns' />
        </calculation>
      </column>
      <column datatype='real' name='[Calculation2]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='RUNNING_SUM(SUM([Sales]))'>
          <table-calc ordering-type='Table' />
        </calculation>
      </column>
      <column caption='Profit/Sales' datatype='real' name='[Calculation_1967791612301914118]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Profit]/[Sales]' />
      </column>
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1967791612303233032]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit]) / SUM([Sales])' />
      </column>
      <column caption='Ship Duration' datatype='integer' name='[Calculation_1967791612307628041]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Ship Date]-[Order Date]' />
      </column>
      <column caption='Profit Updated' datatype='real' name='[Calculation_1967791612311023627]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IFNULL([Profit],0)' />
      </column>
      <column caption='Customer Name-Updated' datatype='string' name='[Calculation_1967791612311461900]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL([Customer Name], &quot;Unknown&quot;)' />
      </column>
      <column caption='Profitable' datatype='string' name='[Calculation_1967791612316295181]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit] )&gt; 10000 THEN &quot;Profitable&quot;&#13;&#10;ELSE &quot;Non-Profitable&quot;&#13;&#10;END' />
      </column>
      <column caption='Sales &gt;50K' datatype='boolean' name='[Calculation_1967791612318191630]' role='measure' type='nominal'>
        <calculation class='tableau' formula='SUM([Sales]) &gt; 50000' />
