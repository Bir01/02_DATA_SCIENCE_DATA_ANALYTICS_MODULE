      <aliases enabled='yes' />
      <column caption='Profit per City(INCLUDE)' datatype='real' name='[Calculation_1967510138025811968]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ INCLUDE  [City]  :  SUM([Profit])  }' />
      </column>
      <column caption='Sales per Customer(INCLUDE)' datatype='real' name='[Calculation_1967510138028965889]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{INCLUDE [Customer Name] : SUM([Sales])}' />
      </column>
      <column aggregation='Attribute' caption='Sales per State(EXCLUDE)' datatype='real' name='[Calculation_1967510138034782210]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ EXCLUDE  [City]  :  SUM([Sales])  }' />
      </column>
      <column caption='Profit per Country(FIXED)' datatype='real' name='[Calculation_1967510138040098822]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{ FIXED  [Country/Region] : SUM([Profit]) }' />
      </column>
      <column caption='Grand Total' datatype='real' name='[Calculation_1967510138041253895]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED : SUM([Sales])}' />
      </column>
      <column aggregation='Attribute' caption='Grand Total(EXCLUDE)' datatype='real' name='[Calculation_1967510138042560520]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{EXCLUDE [Category], [Sub-Category] : SUM([Sales])}' />
      </column>
