      <aliases enabled='yes' />
      <column caption='Measure Names' datatype='string' name='[:Measure Names]' role='dimension' type='nominal' />
      <column caption='Cases Measure' datatype='integer' name='[Calculation_2073063255787503618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Daily Change&quot; THEN [people_positive_new_cases_count]&#13;&#10;WHEN &quot;Cumulative&quot; THEN [people_positive_cases_count]&#13;&#10;END' />
      </column>
      <column caption='Min Date' datatype='date' name='[Calculation_662873622741966848]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{MIN([report_date])}' />
      </column>
      <column caption='Max Date' datatype='date' name='[Calculation_662873622742716417]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{MAX([report_date])}' />
      </column>
      <column caption='Max Date for US' datatype='date' name='[Calculation_662873622749257730]' role='dimension' type='ordinal'>
        <calculation class='tableau' formula='{&#13;&#10;MAX(IF [country_short_name]= &quot;United States&quot; THEN [report_date] END)&#13;&#10;}' />
      </column>
      <column caption='Date is Less Than or Equal to US Date' datatype='boolean' name='[Calculation_662873622749646851]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[report_date] &lt;= [Calculation_662873622749257730]&#13;&#10;// The US data is one day behing the Global data as they come&#13;&#10;//from two different sources.&#13;&#10;//This filter enures we are reporting based on the Max US date' />
      </column>
      <column caption='Total or New Positive Cases' datatype='integer' name='[Calculation_662873622752280581]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;New&quot; THEN [people_positive_new_cases_count]&#13;&#10;ELSE [people_positive_cases_count] END' />
      </column>
      <column caption='Total or New Deaths' datatype='integer' name='[Calculation_662873622752518150]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;New&quot; THEN [people_death_new_count]&#13;&#10;ELSE [people_death_count] END' />
      </column>
      <column caption='Date is Max' datatype='boolean' name='[Calculation_662873622753488903]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_662873622742716417] = [report_date]&#13;&#10;//Used to report on the latest day of data. Use when using&#13;&#10;//Cumulative numbers to only show the most recent' />
      </column>
      <column caption='Current Day Cumulative or New Positive Cases' datatype='integer' name='[Calculation_662873622753910792]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_662873622753488903] THEN [Calculation_662873622752280581] END' />
      </column>
      <column caption='Previous Day Cumulative or New Positive Cases' datatype='integer' name='[Calculation_662873622754512905]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF Datediff(&apos;day&apos;,[report_date],[Calculation_662873622742716417]) =1 THEN [Calculation_662873622752280581] END' />
      </column>
      <column caption='Difference in Cumulative or New to Previous Day Positive Cases' datatype='integer' name='[Calculation_662873622755315722]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_662873622753910792])-SUM([Calculation_662873622754512905])' />
      </column>
      <column caption='Difference in Cumulative or New Positive Cases to Previous Day %' datatype='real' name='[Calculation_662873622755930123]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_662873622755315722] / SUM([Calculation_662873622754512905])' />
      </column>
      <column caption='Difference in Cumulative or New Positive Cases Up' datatype='string' name='[Calculation_662873622757101580]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_662873622755315722]&gt;0 THEN &quot;▲&quot; END' />
      </column>
      <column caption='Difference in Cumulative or New Positive Cases Same' datatype='string' name='[Calculation_662873622757359629]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF[Calculation_662873622755315722]=0 THEN &quot;●&quot; END' />
      </column>
      <column caption='Difference in Cumulative or New Positive Cases Down' datatype='string' name='[Calculation_662873622757580814]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_662873622755315722]&lt;0 THEN &quot;▼&quot; END' />
      </column>
      <column caption='Previous Day Cumulative or New Deaths' datatype='integer' name='[Calculation_662873622772285458]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF Datediff(&apos;day&apos;,[report_date],[Calculation_662873622742716417]) = 1 THEN [Calculation_662873622752518150] END' />
      </column>
      <column caption='Difference in Cumulative or New to Previous Day Deaths' datatype='integer' name='[Calculation_662873622772437011]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Current Day Cumulative or New Positive Cases (copy)_662873622771687441]) - SUM([Calculation_662873622772285458])' />
      </column>
      <column caption='Difference in Cumulative or New Deaths to Previous Day %' datatype='real' name='[Calculation_662873622772588564]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_662873622772437011] / SUM([Calculation_662873622772285458])' />
      </column>
      <column caption='Difference in Cumulative or New Deaths Down' datatype='string' name='[Calculation_662873622777720853]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_662873622772437011]&lt;0 THEN &quot;▼&quot; END' />
      </column>
      <column caption='Difference in Cumulative or New Deaths Same' datatype='string' name='[Calculation_662873622778023958]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_662873622772437011] = 0 THEN &quot;●&quot; END' />
      </column>
      <column caption='Difference in Cumulative or New Deaths Up' datatype='string' name='[Calculation_662873622778220567]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_662873622772437011]&gt;0 THEN &quot;▲&quot; END' />
      </column>
      <column caption='Selected Metric Header' datatype='string' name='[Calculation_662873622785191960]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Parameters].[Parameter 3] + &quot; &quot; + [Parameters].[Parameter 4]' />
      </column>
      <column caption='Selected Metric' datatype='integer' name='[Calculation_662873622785716249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;Cumulative&quot; and [Parameters].[Parameter 4] = &quot;Positive Cases&quot;&#13;&#10;THEN [people_positive_cases_count]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;New&quot; and [Parameters].[Parameter 4] = &quot;Positive Cases&quot;&#13;&#10;THEN [people_positive_new_cases_count]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;New&quot; and [Parameters].[Parameter 4] = &quot;Deaths&quot;&#13;&#10;THEN [people_death_new_count]&#13;&#10;ELSEIF [Parameters].[Parameter 3] = &quot;Cumulative&quot; and [Parameters].[Parameter 4] = &quot;Deaths&quot;&#13;&#10;THEN [people_death_count]&#13;&#10;END' />
      </column>
      <column caption='Deaths Measure' datatype='integer' name='[Cases Measure (copy)_2073063255789899780]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='CASE [Parameters].[Parameter 2]&#13;&#10;WHEN &quot;Daily Change&quot; THEN [people_death_new_count]&#13;&#10;WHEN &quot;Cumulative&quot; THEN [people_death_count]&#13;&#10;END' />
      </column>
      <column caption='Current Day Cumulative or New Deaths' datatype='integer' name='[Current Day Cumulative or New Positive Cases (copy)_662873622771687441]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Calculation_662873622753488903] THEN [Calculation_662873622752518150]  END' />
