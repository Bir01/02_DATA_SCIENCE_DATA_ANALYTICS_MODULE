  <worksheets>
    <worksheet name=' Global Deaths BAN'>
      <table>
        <view>
          <datasources>
            <datasource caption='covid-19-data-resource-hub/covid-19-case-counts' name='federated.0dheax011uroih103am5f13iqpc4' />
            <datasource name='Parameters' />
          </datasources>
          <datasource-dependencies datasource='Parameters'>
            <column caption='Cumulative or New' datatype='string' name='[Parameter 3]' param-domain-type='list' role='measure' type='nominal' value='&quot;Cumulative&quot;'>
              <calculation class='tableau' formula='&quot;Cumulative&quot;' />
            </column>
          </datasource-dependencies>
          <datasource-dependencies datasource='federated.0dheax011uroih103am5f13iqpc4'>
            <column caption='Max Date' datatype='date' name='[Calculation_662873622742716417]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{MAX([report_date])}' />
            </column>
            <column caption='Max Date for US' datatype='date' name='[Calculation_662873622749257730]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{&#13;&#10;MAX(IF [country_short_name]= &quot;United States&quot; THEN [report_date] END)&#13;&#10;}' />
            </column>
            <column caption='Date is Less Than or Equal to US Date' datatype='boolean' name='[Calculation_662873622749646851]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[report_date] &lt;= [Calculation_662873622749257730]&#13;&#10;// The US data is one day behing the Global data as they come&#13;&#10;//from two different sources.&#13;&#10;//This filter enures we are reporting based on the Max US date' />
            </column>
            <column caption='Total or New Deaths' datatype='integer' name='[Calculation_662873622752518150]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Parameters].[Parameter 3] = &quot;New&quot; THEN [people_death_new_count]&#13;&#10;ELSE [people_death_count] END' />
            </column>
            <column caption='Date is Max' datatype='boolean' name='[Calculation_662873622753488903]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_662873622742716417] = [report_date]&#13;&#10;//Used to report on the latest day of data. Use when using&#13;&#10;//Cumulative numbers to only show the most recent' />
            </column>
            <column caption='Previous Day Cumulative or New Deaths' datatype='integer' name='[Calculation_662873622772285458]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF Datediff(&apos;day&apos;,[report_date],[Calculation_662873622742716417]) = 1 THEN [Calculation_662873622752518150] END' />
            </column>
            <column caption='Difference in Cumulative or New to Previous Day Deaths' datatype='integer' name='[Calculation_662873622772437011]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='SUM([Current Day Cumulative or New Positive Cases (copy)_662873622771687441]) - SUM([Calculation_662873622772285458])' />
            </column>
            <column caption='Difference in Cumulative or New Deaths to Previous Day %' datatype='real' name='[Calculation_662873622772588564]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[Calculation_662873622772437011] / SUM([Calculation_662873622772285458])' />
            </column>
            <column caption='Difference in Cumulative or New Deaths Down' datatype='string' name='[Calculation_662873622777720853]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_662873622772437011]&lt;0 THEN &quot;▼&quot; END' />
            </column>
            <column caption='Difference in Cumulative or New Deaths Same' datatype='string' name='[Calculation_662873622778023958]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_662873622772437011] = 0 THEN &quot;●&quot; END' />
            </column>
            <column caption='Difference in Cumulative or New Deaths Up' datatype='string' name='[Calculation_662873622778220567]' role='measure' type='nominal'>
              <calculation class='tableau' formula='IF [Calculation_662873622772437011]&gt;0 THEN &quot;▲&quot; END' />
            </column>
            <column caption='Current Day Cumulative or New Deaths' datatype='integer' name='[Current Day Cumulative or New Positive Cases (copy)_662873622771687441]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='IF [Calculation_662873622753488903] THEN [Calculation_662873622752518150]  END' />
            </column>
            <column caption='Country Short Name' datatype='string' name='[country_short_name]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal'>
              <semantic-values semantic-role='[Geographical].[Latitude]'>
                <semantic-value key='&quot;St Martin&quot;' value='18.265897055058527' />
              </semantic-values>
              <semantic-values semantic-role='[Geographical].[Longitude]'>
                <semantic-value key='&quot;St Martin&quot;' value='-63.061509449454121' />
              </semantic-values>
            </column>
            <column-instance column='[Calculation_662873622749646851]' derivation='None' name='[none:Calculation_662873622749646851:nk]' pivot='key' type='nominal' />
            <column caption='People Death Count' datatype='integer' name='[people_death_count]' role='measure' type='quantitative' />
            <column caption='People Death New Count' datatype='integer' name='[people_death_new_count]' role='measure' type='quantitative' />
